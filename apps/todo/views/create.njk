{% extends "layout.njk" %}

{% block content %}

    <div class="container py-4 px-3 mx-auto">
        <h1 data-testid="create-heading">New Todo</h1>

        <form action="/todos/create" method="POST">
            <div class="mb-3">
                <label for="title" class="form-label" data-testid="title-label">Title</label>
                <input
                    type="text"
                    name="title"
                    class="form-control {% if errors.title %} is-invalid {% endif %}"
                    id="title"
                    data-testid="title-input"
                    aria-describedby="title">

                {% if errors.title %}
                    <div class="invalid-feedback" data-testid="title-error">
                        {{errors.title}}
                    </div>
                {% endif %}

            </div>

            <button type="submit" class="btn btn-primary" data-testid="submit-button">Submit</button>
        </form>
    </div>

{% endblock content %}
