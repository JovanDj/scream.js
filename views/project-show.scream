{% extends "layout.scream" %}

{% block title %}Project | {{ project.name }}{% endblock title %}

{% block content %}
<div class="container py-4 px-3 mx-auto">
    <section class="page-shell">
        <h1 class="page-title mb-3">{{ project.name }}</h1>
        <p class="mb-3">Status: {{ project.statusCode }}</p>
    </section>
</div>
{% endblock content %}
